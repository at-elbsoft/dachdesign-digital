{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{webp,png,jpg,jpeg,svg,ico,xml,txt,js,css,woff,woff2}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "mimeTypes": {
    ".webp": "image/webp",
    ".json": "application/json"
  }
}
